    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug example 'winit'",
            "cargo": {
                "args": [
                    "build",
                    "--example=winit",
                    "--features=winit-support",
                ],
                "filter": {
                    "name": "winit",
                    "kind": "example"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/viewer"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug example 'egui-demo'",
            "cargo": {
                "cwd": "${workspaceFolder}/duck",
                "args": [
                    "build",
                    "-p=egui-demo",
                    "--all-features"
                ],
                "filter": {
                    "name": "egui-demo",
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/duck/egui-demo"
        },
    ]
}